{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://get-paper-done.local/schemas/config.schema.json",
  "title": "GPD Paper Config",
  "type": "object",
  "required": [
    "mode",
    "classification",
    "default_length",
    "citation_style",
    "research",
    "review"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["lite", "standard", "flagship"]
    },
    "classification": {
      "type": "object",
      "required": ["purpose", "channel", "risk", "complexity", "audience_shape"],
      "properties": {
        "purpose": {
          "type": "string",
          "enum": ["decision_memo", "strategy_paper", "explainer", "update"]
        },
        "channel": {
          "type": "string",
          "enum": ["internal", "external", "mixed"]
        },
        "risk": {
          "type": "string",
          "enum": ["internal_low", "internal_high", "external_low", "external_high", "regulated"]
        },
        "complexity": {
          "type": "string",
          "enum": ["light", "standard", "deep"]
        },
        "audience_shape": {
          "type": "string",
          "enum": ["single", "prioritized_multi", "hybrid"]
        }
      }
    },
    "paper_type": {
      "type": "string",
      "description": "Optional legacy/display label. Use classification.purpose for workflow logic.",
      "minLength": 1
    },
    "default_length": {
      "type": "object",
      "required": ["newsletter", "blog", "memo", "update", "position_paper", "white_paper"],
      "properties": {
        "newsletter": { "type": "string", "minLength": 1 },
        "blog": { "type": "string", "minLength": 1 },
        "memo": { "type": "string", "minLength": 1 },
        "update": { "type": "string", "minLength": 1 },
        "position_paper": { "type": "string", "minLength": 1 },
        "white_paper": { "type": "string", "minLength": 1 }
      }
    },
    "citation_style": { "type": "string", "minLength": 1 },
    "research": {
      "type": "object",
      "required": ["web_allowed", "require_source_table", "flag_unsupported_claims"],
      "properties": {
        "web_allowed": { "type": "boolean" },
        "require_source_table": { "type": "boolean" },
        "flag_unsupported_claims": { "type": "boolean" }
      }
    },
    "review": {
      "type": "object",
      "required": [
        "audience_fit",
        "opposition_review",
        "fact_check",
        "persona_consistency"
      ],
      "properties": {
        "audience_fit": { "type": "boolean" },
        "opposition_review": { "type": "boolean" },
        "fact_check": { "type": "boolean" },
        "persona_consistency": { "type": "boolean" },
        "external_models": {
          "type": "object",
          "properties": {
            "claude": {
              "type": "object",
              "properties": {
                "model": { "type": "string", "minLength": 1 },
                "effort": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "xhigh", "max"]
                }
              },
              "additionalProperties": false
            },
            "gemini": {
              "type": "object",
              "properties": {
                "model": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    }
  }
}
