{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://get-paper-done.local/schemas/state.schema.json",
  "title": "GPD State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "current_stage",
    "last_completed_stage",
    "last_activity",
    "suggested_next_command",
    "blocked_by",
    "grill",
    "strategy",
    "feedback",
    "post_import_choices"
  ],
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "status": { "type": "string", "minLength": 1 },
    "current_stage": { "type": "string", "minLength": 1 },
    "last_completed_stage": { "type": "string", "minLength": 1 },
    "last_activity": { "type": "string", "minLength": 1 },
    "suggested_next_command": {
      "type": "string",
      "minLength": 1,
      "pattern": "^/gpd-[a-z0-9-]+(?:\\s+.*)?$"
    },
    "blocked_by": {
      "type": "array",
      "items": { "type": "string" }
    },
    "grill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "completion_basis", "resolved_decisions"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["Not Started", "In Progress", "Complete"]
        },
        "completion_basis": { "type": "string" },
        "resolved_decisions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "paper_job",
              "primary_reader",
              "belief_shift",
              "thesis",
              "narrative_spine",
              "key_terms",
              "scope_boundary",
              "proof_standard",
              "strongest_counterargument",
              "non_goals"
            ]
          }
        }
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "blocking_issues",
        "primary_blocker",
        "block_severity",
        "required_unblock_action"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["Go", "Revise Before Drafting", "No-Go"]
        },
        "blocking_issues": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "none",
              "scope_too_broad",
              "thesis_weak",
              "audience_unclear",
              "audience_conflict",
              "evidence_gap",
              "weak_ask",
              "poor_posture",
              "missing_outcome",
              "reader_promise_weak",
              "decision_usefulness_weak"
            ]
          }
        },
        "primary_blocker": {
          "type": "string",
          "enum": [
            "none",
            "scope_too_broad",
            "thesis_weak",
            "audience_unclear",
            "audience_conflict",
            "evidence_gap",
            "weak_ask",
            "poor_posture",
            "missing_outcome",
            "reader_promise_weak",
            "decision_usefulness_weak"
          ]
        },
        "block_severity": {
          "type": "string",
          "enum": ["None", "Medium", "High"]
        },
        "required_unblock_action": {
          "type": "string",
          "enum": [
            "none",
            "brief_revision",
            "audience_revision",
            "thesis_revision",
            "scope_narrowing",
            "research_plan",
            "user_override"
          ]
        }
      }
    },
    "feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feedback_plan_status", "approved_handling"],
      "properties": {
        "feedback_plan_status": { "type": "string" },
        "approved_handling": { "type": "string" }
      }
    },
    "post_import_choices": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
