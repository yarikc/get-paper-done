{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://get-paper-done.local/schemas/research.schema.json",
  "title": "GPD Research",
  "type": "object",
  "required": [
    "metadata",
    "research_plan",
    "research_brief",
    "source_ranking",
    "source_registry",
    "evidence_matrix",
    "synthesis_matrix",
    "contradictions",
    "open_questions",
    "draft_support_notes",
    "facts_safe_to_use",
    "claims_to_soften",
    "claims_to_drop_or_reframe"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["topic", "scope", "depth", "source_mode", "created_at", "updated_at"],
      "properties": {
        "topic": { "type": "string" },
        "scope": { "type": "string" },
        "depth": { "type": "string" },
        "source_mode": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "research_plan": {
      "type": "object",
      "required": [
        "inferred_research_questions",
        "depth_rationale",
        "source_mode_rationale",
        "user_feedback"
      ],
      "properties": {
        "inferred_research_questions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "question",
              "mapped_claims",
              "why_it_matters",
              "planned_source_types",
              "search_queries"
            ],
            "properties": {
              "id": { "type": "string" },
              "question": { "type": "string" },
              "mapped_claims": {
                "type": "array",
                "items": { "type": "string" }
              },
              "why_it_matters": { "type": "string" },
              "planned_source_types": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["official", "academic", "industry", "news", "analyst", "blog", "user_provided", "other"]
                }
              },
              "search_queries": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "depth_rationale": { "type": "string" },
        "source_mode_rationale": { "type": "string" },
        "source_lanes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lane", "purpose", "planned_source_types", "expected_examples", "status"],
            "properties": {
              "lane": {
                "type": "string",
                "enum": [
                  "official_regulatory_standards",
                  "empirical_counterevidence",
                  "industry_trend_market",
                  "practitioner_operating_model"
                ]
              },
              "purpose": { "type": "string" },
              "planned_source_types": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["official", "academic", "industry", "news", "analyst", "blog", "user_provided", "other"]
                }
              },
              "expected_examples": {
                "type": "array",
                "items": { "type": "string" }
              },
              "status": {
                "type": "string",
                "enum": ["planned", "covered", "not_applicable", "missing"]
              }
            }
          }
        },
        "author_language_queries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phrase", "source_artifact", "derived_queries", "why_it_matters"],
            "properties": {
              "phrase": { "type": "string" },
              "source_artifact": { "type": "string" },
              "derived_queries": {
                "type": "array",
                "items": { "type": "string" }
              },
              "why_it_matters": { "type": "string" }
            }
          }
        },
        "expected_source_checkpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["asked", "user_response", "sources_expected"],
          "properties": {
            "asked": { "type": "boolean" },
            "user_response": { "type": "string" },
            "sources_expected": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "missed_source_audit": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "status", "miss_category", "reason", "prevention"],
            "properties": {
              "source": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["open", "resolved", "deferred"]
              },
              "miss_category": {
                "type": "string",
                "enum": [
                  "absent_source_lane",
                  "source_added_after_research",
                  "underweighted_source_type",
                  "terminology_mismatch",
                  "not_discoverable",
                  "agent_error"
                ]
              },
              "reason": { "type": "string" },
              "prevention": { "type": "string" }
            }
          }
        },
        "user_feedback": { "type": "string" }
      }
    },
    "research_brief": {
      "type": "object",
      "required": ["executive_summary", "key_findings"],
      "properties": {
        "executive_summary": { "type": "string" },
        "key_findings": { "type": "array" }
      }
    },
    "source_ranking": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "source_id",
          "rank_group",
          "role",
          "why_picked",
          "ranking_reason",
          "limitations"
        ],
        "properties": {
          "rank": { "type": "integer" },
          "source_id": { "type": "string" },
          "rank_group": {
            "type": "string",
            "enum": ["primary_anchor", "secondary_anchor", "trend_evidence", "failure_mode_evidence", "analogy", "background"]
          },
          "role": {
            "type": "string",
            "enum": [
              "primary_regulatory_anchor",
              "lifecycle_control_anchor",
              "industry_trend_evidence",
              "failure_mode_evidence",
              "analogy_source",
              "counterevidence",
              "background"
            ]
          },
          "why_picked": { "type": "string" },
          "ranking_reason": { "type": "string" },
          "limitations": { "type": "string" }
        }
      }
    },
    "source_registry": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "url_or_path",
          "rank_group",
          "source_type",
          "authority",
          "freshness",
          "relevance",
          "specificity",
          "bias_or_agenda",
          "stance",
          "why_picked",
          "short_summary",
          "relevant_points",
          "use_in_paper",
          "limitations",
          "notes"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "url_or_path": { "type": "string" },
          "rank_group": {
            "type": "string",
            "enum": ["primary_anchor", "secondary_anchor", "trend_evidence", "failure_mode_evidence", "analogy", "background"]
          },
          "source_type": {
            "type": "string",
            "enum": ["official", "academic", "industry", "news", "analyst", "blog", "user_provided", "other"]
          },
          "authority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "freshness": {
            "type": "string",
            "enum": ["recent", "moderate", "old", "unknown"]
          },
          "relevance": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "specificity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "bias_or_agenda": { "type": "string" },
          "stance": {
            "type": "string",
            "enum": ["supportive", "neutral", "critical", "mixed"]
          },
          "why_picked": { "type": "string" },
          "short_summary": { "type": "string" },
          "relevant_points": {
            "type": "array",
            "items": { "type": "string" }
          },
          "use_in_paper": { "type": "string" },
          "limitations": { "type": "string" },
          "claim_support": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["claim_id", "support", "rationale"],
              "properties": {
                "claim_id": { "type": "string" },
                "support": {
                  "type": "string",
                  "enum": ["direct", "partial", "topical_only", "contradicts", "not_checked"]
                },
                "rationale": { "type": "string" }
              }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "evidence_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "claim",
          "claim_type",
          "research_questions",
          "supporting_sources",
          "contradicting_sources",
          "strength_of_support",
          "confidence",
          "recommended_handling",
          "notes"
        ],
        "properties": {
          "claim_id": { "type": "string" },
          "claim": { "type": "string" },
          "claim_type": {
            "type": "string",
            "enum": [
              "factual",
              "causal",
              "strategic_judgment",
              "technical_mechanism",
              "market_trend",
              "recommendation"
            ]
          },
          "research_questions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supporting_sources": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contradicting_sources": {
            "type": "array",
            "items": { "type": "string" }
          },
          "strength_of_support": {
            "type": "string",
            "enum": ["strong", "moderate", "weak", "none"]
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "recommended_handling": {
            "type": "string",
            "enum": ["keep", "support_more", "soften", "narrow", "caveat", "drop"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "evidence_nuggets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "nugget", "source_ids", "use_in_draft", "caveat"],
        "properties": {
          "claim_id": { "type": "string" },
          "nugget": { "type": "string" },
          "source_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "use_in_draft": { "type": "string" },
          "caveat": { "type": "string" }
        }
      }
    },
    "synthesis_matrix": {
      "type": "object",
      "required": ["themes", "rows"],
      "properties": {
        "themes": { "type": "array" },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "theme",
              "source_summaries",
              "pattern",
              "implication"
            ],
            "properties": {
              "theme": { "type": "string" },
              "source_summaries": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "pattern": {
                "type": "string",
                "enum": ["agreement", "disagreement", "mixed", "gap"]
              },
              "implication": { "type": "string" }
            }
          }
        }
      }
    },
    "contradictions": { "type": "array" },
    "open_questions": { "type": "array" },
    "draft_support_notes": { "type": "array" },
    "facts_safe_to_use": { "type": "array" },
    "claims_to_soften": { "type": "array" },
    "claims_to_drop_or_reframe": { "type": "array" }
  }
}
